{
  "id": "npqs-visual-consignment--officer-form",
  "title": "Consignment Visual Inspection Outcome",
  "schema": {
    "type": "object",
    "properties": {
      "visual_result": {
        "type": "string",
        "title": "Inspection Result",
        "oneOf": [
          { "const": "pass", "title": "Pass (Consignment approved visually)" },
          { "const": "fail", "title": "Fail (Consignment has pests, rot, or damage)" }
        ],
        "default": "pass"
      },
      "inspection_comments": {
        "type": "string",
        "title": "Inspection Notes",
        "example": "Conducted visual inspection of packages at port. Storage conditions are acceptable, all seals intact."
      }
    },
    "required": [
      "visual_result"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/visual_result"
      },
      {
        "type": "Control",
        "scope": "#/properties/inspection_comments"
      }
    ]
  }
}
