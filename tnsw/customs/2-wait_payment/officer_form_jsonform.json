{
  "id": "customs-payment-wait--officer-form",
  "title": "Confirm Customs Payment",
  "schema": {
    "type": "object",
    "properties": {
      "payment_status": {
        "type": "string",
        "title": "Payment Status",
        "oneOf": [
          { "const": "success", "title": "Payment Confirmed & Settled" }
        ],
        "default": "success"
      },
      "receipt_number": {
        "type": "string",
        "title": "Customs Receipt Number",
        "example": "REC-948201"
      }
    },
    "required": [
      "payment_status",
      "receipt_number"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/payment_status"
      },
      {
        "type": "Control",
        "scope": "#/properties/receipt_number"
      }
    ]
  }
}
