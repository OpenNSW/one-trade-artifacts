{
  "id": "customs-workflow",
  "name": "Customs Declaration & Clearance Process",
  "version": 2,
  "nodes": [
    {
      "id": "start",
      "type": "START",
      "name": "Start"
    },
    {
      "id": "customs_1_cusdec_submission",
      "type": "TASK",
      "name": "[Customs 1.0] Submit CusDec",
      "task_template_id": "customs-cusdec-apply-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "_iter.input.trader_company?": "trader_company"
      },
      "output_mapping": {
        "reviewerform.review_outcome": "customs.cusdec_review_outcome",
        "reviewerform.cusdec_number": "customs.cusdec_number",
        "userform": "customs.userform"
      }
    },
    {
      "id": "customs_1b_emit_cusdec_ready",
      "type": "TASK",
      "name": "[Customs 1b] Broadcast CusDec Number to Sibling Flows",
      "task_template_id": "sys:emit_signal",
      "lane": "Trader/CHA",
      "input_mapping": {
        "_iter.input.cusdec_signal": "signal_name",
        "customs.cusdec_number": "payload.cusdec_number"
      },
      "output_mapping": {}
    },
    {
      "id": "end",
      "type": "END",
      "name": "CusDec Issued"
    }
  ],
  "edges": [
    {
      "id": "e_start_to_1",
      "source_id": "start",
      "target_id": "customs_1_cusdec_submission"
    },
    {
      "id": "e_1_to_1b",
      "source_id": "customs_1_cusdec_submission",
      "target_id": "customs_1b_emit_cusdec_ready"
    },
    {
      "id": "e_1b_to_end",
      "source_id": "customs_1b_emit_cusdec_ready",
      "target_id": "end"
    }
  ]
}
