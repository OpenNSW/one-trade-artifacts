{
  "id": "customs-cdn--user-form",
  "title": "Cargo Dispatch Note (CDN) Application",
  "schema": {
    "type": "object",
    "properties": {
      "shipper_name_address": {
        "type": "string",
        "title": "1.a Shipper Name & Address",
        "example": "ACME Premium Food Exports Ltd., No 18, Galle Road, Colombo 03"
      },
      "cusdec_numbers": {
        "type": "string",
        "title": "1.b Cusdec Numbers",
        "example": "CUSDEC-2026-89421"
      },
      "brsl_selection": {
        "type": "string",
        "title": "2. B / R / S / L Selection",
        "oneOf": [
          { "const": "B", "title": "B" },
          { "const": "R", "title": "R" },
          { "const": "S", "title": "S" },
          { "const": "L", "title": "L" }
        ],
        "default": "B"
      },
      "consignee_name_address": {
        "type": "string",
        "title": "2.b Consignee Name & Address",
        "example": "Hamburg Fine Foods Import GMBH, Industriestrasse 104, Hamburg"
      },
      "voyage_no_date": {
        "type": "string",
        "title": "3.a Voyage No. / Date",
        "example": "V092 - 2026-06-25"
      },
      "ex_vessel": {
        "type": "string",
        "title": "3.b Ex Vessel"
      },
      "vessel": {
        "type": "string",
        "title": "4. Vessel",
        "example": "CMA CGM MARCO POLO"
      },
      "port_of_discharge": {
        "type": "string",
        "title": "5. Port of Discharge",
        "example": "Port of Hamburg (DEHAM)"
      },
      "vessel_op_code": {
        "type": "string",
        "title": "Vessel Op. Code",
        "example": "OP-MSC"
      },
      "cont_op_code": {
        "type": "string",
        "title": "Cont. Op. Code",
        "example": "CO-882"
      },
      "port_of_loading": {
        "type": "string",
        "title": "6. Port of Loading",
        "example": "Port of Colombo (LKCMB)"
      },
      "lorry_trailer_no": {
        "type": "string",
        "title": "7. Lorry/Trailer No",
        "example": "WP-LY-4920"
      },
      "sn_bl_no": {
        "type": "string",
        "title": "8. SN(B/L) No",
        "example": "BL-9382019-COL"
      },
      "tare_weight": {
        "type": "number",
        "title": "9. Tare Wt. (Kg)",
        "example": 2200
      },

      "seal_no": {
        "type": "string",
        "title": "11.a Seal No",
        "example": "894021"
      },
      "cdn_number": {
        "type": "string",
        "title": "CDN No",
        "example": "CDN-2026-00481"
      },
      "driver_name": {
        "type": "string",
        "title": "12. Name of the Driver",
        "example": "K. A. Sunil Perera"
      },
      "location_of_goods": {
        "type": "string",
        "title": "13. Location of Goods",
        "example": "CFS 1, Port of Colombo"
      },
      "any_other_accompanying": {
        "type": "string",
        "title": "14. Any other Accompanying Document details"
      },
      "departure_time": {
        "type": "string",
        "title": "15. Time of Departure from Stores/CFS",
        "example": "10:30 AM"
      },
      "certifying_officer": {
        "type": "string",
        "title": "16. Name of certifying security officer/authorized signatory",
        "example": "S. D. Bandara"
      },
      "signature_designation_date": {
        "type": "string",
        "title": "17. Signature, Designation and Date",
        "example": "S.D. Bandara, Chief Security Officer - 2026-06-22"
      },
      "container_marks_numbers": {
        "type": "string",
        "title": "18. Marks & Numbers Container No",
        "example": "MSCU-849201-9"
      },
      "number_kind_packages": {
        "type": "string",
        "title": "19. Number & Kind of Packages",
        "example": "80 steel drums on 20 wooden pallets"
      },
      "description_of_goods": {
        "type": "string",
        "title": "20. Description of Goods",
        "example": "Refined Organic Coconut Oil"
      },
      "gross_weight": {
        "type": "number",
        "title": "21. (a) Gross Weight Kg",
        "example": 16500.5
      },
      "cube_volume": {
        "type": "number",
        "title": "22. Cube m3",
        "example": 32.5
      },
      "container_type": {
        "type": "string",
        "title": "23. Type of Container (Height...Length...Type..)",
        "example": "20ft GP Standard - 8ft 6in"
      },
      "reefer_temp_required": {
        "type": "number",
        "title": "24. Reefer Temperature Required (°C)"
      },
      "place_of_delivery": {
        "type": "string",
        "title": "25. Place of Delivery (CY / CFS / DOOR)",
        "example": "CY"
      },
      "place_of_receipt": {
        "type": "string",
        "title": "26. Place of Receipt (CY / CFS / DOOR)",
        "example": "CFS"
      },

      "preparing_company_name": {
        "type": "string",
        "title": "34. Name of Company preparing Note",
        "example": "ADAM PVT LTD (CHA)"
      },
      "declarant_name": {
        "type": "string",
        "title": "35. Name of the Declarant",
        "example": "M. T. Fernando"
      },
      "telephone_no": {
        "type": "string",
        "title": "36. Telephone No",
        "example": "0112345678"
      },
      "declarant_signature": {
        "type": "string",
        "title": "37. Signature of Declarant",
        "example": "M. T. Fernando"
      }
    },
    "required": [
      "shipper_name_address",
      "cusdec_numbers",
      "consignee_name_address",
      "voyage_no_date",
      "vessel",
      "port_of_discharge",
      "vessel_op_code",
      "cont_op_code",
      "port_of_loading",
      "lorry_trailer_no",
      "sn_bl_no",
      "tare_weight",
      "seal_no",
      "cdn_number",
      "driver_name",
      "location_of_goods",
      "departure_time",
      "certifying_officer",
      "signature_designation_date",
      "container_marks_numbers",
      "number_kind_packages",
      "description_of_goods",
      "gross_weight",
      "cube_volume",
      "container_type",
      "preparing_company_name",
      "declarant_name",
      "telephone_no"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Group",
        "label": "1. Consignment & General Info",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/cdn_number" },
              { "type": "Control", "scope": "#/properties/cusdec_numbers" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/brsl_selection" },
              { "type": "Control", "scope": "#/properties/location_of_goods" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/shipper_name_address" },
              { "type": "Control", "scope": "#/properties/consignee_name_address" }
            ]
          }
        ]
      },
      {
        "type": "Group",
        "label": "2. Transport & Route Details",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/vessel" },
              { "type": "Control", "scope": "#/properties/voyage_no_date" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/ex_vessel" },
              { "type": "Control", "scope": "#/properties/port_of_loading" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/port_of_discharge" },
              { "type": "Control", "scope": "#/properties/sn_bl_no" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/vessel_op_code" },
              { "type": "Control", "scope": "#/properties/cont_op_code" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/lorry_trailer_no" },
              { "type": "Control", "scope": "#/properties/driver_name" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/departure_time" }
            ]
          }
        ]
      },
      {
        "type": "Group",
        "label": "3. Container & Cargo Details",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/container_marks_numbers" },
              { "type": "Control", "scope": "#/properties/container_type" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/seal_no" },
              { "type": "Control", "scope": "#/properties/tare_weight" }
            ]
          },
          {
            "type": "Control",
            "scope": "#/properties/description_of_goods"
          },
          {
            "type": "Control",
            "scope": "#/properties/number_kind_packages"
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/gross_weight" },
              { "type": "Control", "scope": "#/properties/cube_volume" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/reefer_temp_required" },
              { "type": "Control", "scope": "#/properties/place_of_delivery" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/place_of_receipt" }
            ]
          }
        ]
      },
      {
        "type": "Group",
        "label": "4. Security & Signatures",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/certifying_officer" },
              { "type": "Control", "scope": "#/properties/signature_designation_date" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/preparing_company_name" },
              { "type": "Control", "scope": "#/properties/declarant_name" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/telephone_no" },
              { "type": "Control", "scope": "#/properties/declarant_signature" }
            ]
          }
        ]
      }
    ]
  }
}
