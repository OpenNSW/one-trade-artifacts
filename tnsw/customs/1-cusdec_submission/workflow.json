{
  "id": "customs-cusdec-apply-flow",
  "name": "Submit & Review Customs Declaration",
  "version": 2,
  "nodes": [
    {
      "id": "start",
      "type": "START"
    },
    {
      "id": "applicant_submission",
      "type": "TASK",
      "task_template_id": "customs-cusdec--user-input",
      "input_mapping": {
        "reviewerform.rejection_reason?": "rejection_reason",
        "trader_company.name?": "userform.traders.exporter.name",
        "trader_company.data.tin_no?": "userform.traders.exporter.code"
      },
      "output_mapping": {
        "shipmentType": "userform.shipmentType",
        "containerCount": "userform.containerCount",
        "identification": "userform.identification",
        "traders": "userform.traders",
        "generalInfo": "userform.generalInfo",
        "transport": "userform.transport",
        "financial": "userform.financial",
        "valuation": "userform.valuation",
        "packages": "userform.packages",
        "items": "userform.items"
      }
    },
    {
      "id": "officer_review",
      "type": "TASK",
      "task_template_id": "customs-cusdec--external-review",
      "input_mapping": {
        "userform": "submission"
      },
      "output_mapping": {
        "review_outcome": "reviewerform.review_outcome",
        "rejection_reason?": "reviewerform.rejection_reason",
        "cusdec_number?": "reviewerform.cusdec_number"
      }
    },
    {
      "id": "review_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT"
    },
    {
      "id": "end",
      "type": "END"
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source_id": "start",
      "target_id": "applicant_submission"
    },
    {
      "id": "e2",
      "source_id": "applicant_submission",
      "target_id": "officer_review"
    },
    {
      "id": "e3",
      "source_id": "officer_review",
      "target_id": "review_gateway"
    },
    {
      "id": "e_approve",
      "source_id": "review_gateway",
      "target_id": "end",
      "condition": "reviewerform.review_outcome == 'approve'"
    },
    {
      "id": "e_needs_info",
      "source_id": "review_gateway",
      "target_id": "applicant_submission",
      "condition": "reviewerform.review_outcome == 'needs_more_info'"
    }
  ]
}
