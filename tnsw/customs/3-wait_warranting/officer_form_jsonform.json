{
  "id": "customs-warranting-wait--officer-form",
  "title": "CusDec Warranting Action",
  "schema": {
    "type": "object",
    "properties": {
      "warranting_status": {
        "type": "string",
        "title": "Warranting Status",
        "oneOf": [
          { "const": "warranted", "title": "CusDec Warranted" }
        ],
        "default": "warranted"
      },
      "warrant_number": {
        "type": "string",
        "title": "Customs Warrant Number",
        "example": "WRNT-2026-90421"
      }
    },
    "required": [
      "warranting_status",
      "warrant_number"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/warranting_status"
      },
      {
        "type": "Control",
        "scope": "#/properties/warrant_number"
      }
    ]
  }
}
