{
  "id": "customs-export-release-wait--officer-form",
  "title": "Authorize Export Release",
  "schema": {
    "type": "object",
    "properties": {
      "release_status": {
        "type": "string",
        "title": "Release Status",
        "oneOf": [
          { "const": "released", "title": "Authorize Final Export Release" }
        ],
        "default": "released"
      },
      "release_number": {
        "type": "string",
        "title": "Export Release Number",
        "example": "REL-99281-COL"
      }
    },
    "required": [
      "release_status",
      "release_number"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/release_status"
      },
      {
        "type": "Control",
        "scope": "#/properties/release_number"
      }
    ]
  }
}
